# Supabase project credentials — copy this file to .env and fill in real values
# from the Supabase dashboard (Project Settings → API).
# EXPO_PUBLIC_* vars are exposed to the client bundle by Expo automatically.
EXPO_PUBLIC_SUPABASE_URL=REPLACE_WITH_SUPABASE_PROJECT_URL
EXPO_PUBLIC_SUPABASE_ANON_KEY=REPLACE_WITH_SUPABASE_ANON_KEY
