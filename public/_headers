# Cloudflare Pages headers. Content-hashed assets never change under a given
# name, so cache them forever; keep HTML revalidating so deploys go live at once.
/_expo/static/*
  Cache-Control: public, max-age=31536000, immutable

/assets/*
  Cache-Control: public, max-age=31536000, immutable

/*.html
  Cache-Control: public, max-age=0, must-revalidate
