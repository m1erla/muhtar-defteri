# Cloudflare headers (honored by Workers Static Assets — verified live: hashed
# assets return immutable, HTML must-revalidate). Content-hashed assets never
# change under a given name, so cache them forever; keep HTML revalidating so
# deploys go live at once.
/_expo/static/*
  Cache-Control: public, max-age=31536000, immutable

/assets/*
  Cache-Control: public, max-age=31536000, immutable

# The Adana margin art / skyline / mascot (public/decor). Not content-hashed, so
# not immutable — but ~1.4MB of artwork that changes only when we redraw it has no
# business being re-fetched on every visit. A week, revalidated after.
/decor/*
  Cache-Control: public, max-age=604800, stale-while-revalidate=86400

/*.html
  Cache-Control: public, max-age=0, must-revalidate
